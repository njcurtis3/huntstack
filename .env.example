# ─────────────────────────────────────────────────────────────────────────────
# HuntStack — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Use the pooler (Transaction mode) connection string from Supabase dashboard.
# Settings > Database > Connection pooling > Transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase project URL and keys — Settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Frontend (Vite — build-time) ────────────────────────────────────────────
# These must be prefixed with VITE_ to be exposed to the browser bundle.
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=

# URL of the running API server. Change for production deployments.
VITE_API_URL=http://localhost:4001

# MapTiler API key for the map page basemap (map page is currently a stub).
# Get a free key at https://cloud.maptiler.com
VITE_MAPTILER_KEY=

# ─── AI Services (Together.ai) ───────────────────────────────────────────────
# Required for: AI chat (RAG), weekly migration narrative, PDF data extraction.
# Without this key, chat returns 503 and the weekly summary is unavailable.
# Get a key at https://api.together.ai
TOGETHER_API_KEY=

# ─── eBird API (Cornell Lab of Ornithology) ──────────────────────────────────
# Required for: Regional Activity panel, per-refuge community sightings.
# Free key at https://ebird.org/api/keygen
EBIRD_API_KEY=

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Redis (job queue — currently unused) ────────────────────────────────────
# BullMQ is declared but intentionally unwired at V1 scale.
# Leave blank unless you are running a local Redis instance.
REDIS_URL=redis://localhost:6379

# ─── Scraper (optional overrides) ────────────────────────────────────────────
# These have sensible defaults in the scraper code. Override only if needed.
# SCRAPER_USER_AGENT=HuntStack/1.0
# SCRAPER_CONCURRENT_REQUESTS=2
# SCRAPER_DOWNLOAD_DELAY=1
